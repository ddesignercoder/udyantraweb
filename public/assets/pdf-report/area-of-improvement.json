{
  "personalDevelopmentSkills": [
    {
      "id": 1,
      "title": "Self-Awareness & Emotional Intelligence",
      "forStudents": {
        "definition": "Understanding your emotions, strengths, weaknesses, and reactions so you can make better choices in studies and relationships.",
        "howToImprove": [
          "Notice what subjects energize vs drain you",
          "Learn to name emotions (not just \"good/bad\")",
          "Reflect after success or failure"
        ],
        "exercises": [
          "Daily mood journal (1 line/day)",
          "\"What went well / What didn't\" after exams",
          "Personality & interest assessments"
        ]
      },
      "forProfessionals": {
        "definition": "The ability to understand your emotional triggers, strengths, blind spots, and impact on others at work.",
        "howToImprove": [
          "Track emotional patterns at work",
          "Accept feedback without defensiveness",
          "Understand stress responses"
        ],
        "exercises": [
          "Weekly reflection: What triggered me this week?",
          "360-degree feedback",
          "Emotional regulation techniques (pause, label, respond)"
        ]
      }
    },
